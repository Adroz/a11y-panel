{
  "name": "a11y-panel",
  "version": "0.1.0",
  "description": "Chrome Side Panel accessibility testing extension powered by axe-core",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.18"
  },
  "dependencies": {
    "axe-core": "^4.11.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  }
}
